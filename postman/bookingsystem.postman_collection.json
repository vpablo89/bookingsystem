{
  "info": {
    "name": "BookingSystem API",
    "description": "Postman collection for Courts and Reservations API (creates required User/Court ids automatically).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "userId", "value": "" },
    { "key": "courtId", "value": "" },
    { "key": "reservationId", "value": "" }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "POST /users (sets userId)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"User A\"\n}"
            },
            "url": "{{baseUrl}}/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.id) pm.collectionVariables.set('userId', String(body.id));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Courts",
      "item": [
        {
          "name": "POST /courts (sets courtId)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Court A\",\n  \"location\": \"Location A\"\n}"
            },
            "url": "{{baseUrl}}/courts"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.id) pm.collectionVariables.set('courtId', String(body.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /courts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/courts"
          }
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "POST /reservations (creates reservation)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"courtId\": {{courtId}},\n  \"startTime\": \"2026-03-19T10:00:00\",\n  \"endTime\": \"2026-03-19T11:00:00\"\n}"
            },
            "url": "{{baseUrl}}/reservations"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.id) pm.collectionVariables.set('reservationId', String(body.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /reservations",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reservations"
          }
        }
      ]
    }
  ]
}

